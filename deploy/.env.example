# Copy this file to /mnt/user/appdata/opencode/.env (mode 0600) and fill in.

# Telegram
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOTFATHER_TOKEN_HERE
# Comma-separated list of allowed Telegram numeric user IDs.
# Get yours by DMing @userinfobot.
TELEGRAM_ALLOWED_USER_IDS=000000000

# opencode server (basic auth shared between server and bridge)
OPENCODE_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=PUT_RANDOM_32_BYTE_HEX_HERE

# Optional: opencode image build flags
INSTALL_GO_LSP=false
INSTALL_RUST_LSP=false

# Logging
LOG_LEVEL=info

# Default model the bridge passes to opencode when the chat has no per-chat
# model set via /model. opencode otherwise picks its own default which may
# not match the provider account you're authenticated against (e.g. the
# default falls on `openai/gpt-5.5-pro`, which a Codex/ChatGPT subscription
# rejects). Format: <providerID>/<modelID>.
DEFAULT_MODEL=anthropic/claude-sonnet-4-5

# Filesystem paths on the Unraid host (override if you store things elsewhere)
WORKSPACE_HOST_PATH=/mnt/user/code
APPDATA_HOST_PATH=/mnt/user/appdata/opencode

# /init-remote — GitHub PAT with `repo` + `workflow` scopes; owner is your
# GitHub username (or org name) under which new repos are created.
# Leave empty to disable /init-remote (other commands keep working).
GH_TOKEN=
GH_OWNER=

# /deploy — Coolify v4 instance details. See BOOTSTRAP.md section 11
# for one-time setup (Coolify GitHub App + tokens).
# Leave empty to disable /deploy (other commands keep working).
COOLIFY_URL=
COOLIFY_TOKEN=
COOLIFY_SERVER_UUID=
COOLIFY_PROJECT_UUID=
COOLIFY_GITHUB_APP_UUID=
